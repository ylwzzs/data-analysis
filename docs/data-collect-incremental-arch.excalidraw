    { "type": "text", "id": "e_wm_t",
      "x": 84, "y": 2050, "width": 692, "height": 134,
      "text": "// 成功后写回 collect_tasks.params（jsonb 合并）\nparams.watermark = {\n  date        : today,\n  last_count  : result.newApiTotal,   // 本轮 count\n  last_full_ts: now\n}\n// 失败不更新 → 下次多重叠（安全）", "originalText": "// 成功后写回 collect_tasks.params（jsonb 合并）\nparams.watermark = {\n  date        : today,\n  last_count  : result.newApiTotal,   // 本轮 count\n  last_full_ts: now\n}\n// 失败不更新 → 下次多重叠（安全）",

    { "type": "rectangle", "id": "b_ev_bg",
      "x": 70, "y": 792, "width": 640, "height": 226,
      "strokeColor": "#1e293b", "backgroundColor": "#1e293b",
      "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
      "angle": 0, "seed": 102020, "version": 1, "versionNonce": 102021,
      "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "roundness": {"type": 3} },
    { "type": "text", "id": "b_ev_t",
      "x": 84, "y": 804, "width": 612, "height": 200,
      "text": "params = {\n  \"date_mode\"  : \"today\",\n  \"page_size\"  : 200,\n  \"watermark\"  : { date, last_count, last_full_ts }\n}\ndates = [ getTodayChina(), getTodayChina() ]   // 当天双元素\n\n// node-cron 硬编码 Asia/Shanghai\n// */5 8-23 * * *  =  8:00 – 23:55  每 5 分钟", "originalText": "params = {\n  \"date_mode\"  : \"today\",\n  \"page_size\"  : 200,\n  \"watermark\"  : { date, last_count, last_full_ts }\n}\ndates = [ getTodayChina(), getTodayChina() ]   // 当天双元素\n\n// node-cron 硬编码 Asia/Shanghai\n// */5 8-23 * * *  =  8:00 – 23:55  每 5 分钟",
      "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#22c55e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
      "angle": 0, "seed": 102022, "version": 1, "versionNonce": 102023,
      "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false,
      "containerId": null, "lineHeight": 1.4 },


# deploy/.env.example
# 复制为 .env 并填入实际值（cp .env.example .env）。.env 不入库（已 gitignore）。
# 本地开发与生产共用此结构；生产值由服务器上的 .env 提供。

# ============ 数据库 ============
POSTGRES_USER=postgres
POSTGRES_DB=insforge
# 生产务必改成强密码
POSTGRES_PASSWORD=change-me-to-a-strong-password

# ============ InsForge 核心 ============
# JWT 签名密钥（PostgREST 验签）。一旦设定，前端 anon_key 即与它绑定，勿随意更换
# （换了需重新取 anon_key 并重建前端）。
JWT_SECRET=change-me-to-a-long-random-secret
# function secret 解密密钥。必须显式设置为强随机串（openssl rand -hex 32），与 JWT_SECRET 区分。
# compose 已改为缺此项 fail-fast —— 不再回退 JWT_SECRET，防止 key 漂移导致历史 secret 解密失败、
# 注入空串覆盖容器 env 把 function 搞崩。
# 一旦设定也勿随意换：换了老 secret 会变孤儿密文，需重跑 deploy-functions.sh（set_secret 已是
# upsert）用新 key 把全部 secret 重加密一遍自愈。
ENCRYPTION_KEY=please-generate-with-openssl-rand-hex-32
# 管理员账号（登录 dashboard / 调管理 API）
ROOT_ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# ============ InsForge API（部署脚本用） ============
# 本地与生产都用 localhost：dev 经 override 映射端口，prod 经 127.0.0.1 绑定
INSFORGE_URL=http://localhost:7130
# API key（ik_ 开头），部署 function / 设 secret 时鉴权用
INSFORGE_API_KEY=

# ============ 前端 build-time 注入 ============
# 生产填 https://<你的域名>。本地开发前端走 web/.env.local，不读此处
NEXT_PUBLIC_INSFORGE_URL=https://data.example.com
# 本 InsForge 实例的 anon_key（anon_ 前缀）。首次部署后从实例获取并回填此处
NEXT_PUBLIC_INSFORGE_ANON_KEY=

# ============ 企业微信（function secrets，由 deploy-functions.sh 注入到 InsForge） ============
# 注意：这些不是 compose 服务环境变量，而是 edge function 的 secret
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=

# 企微 App B（同步/通知全员应用，架构文档 §7.1）
# 可见范围=全部成员 + 通讯录读取权限；用于通讯录全量同步 + 统一通知
WECOM_OPS_SECRET=
WECOM_OPS_AGENT_ID=
# 统一通知默认收件人（| 分隔的 userid，或 @all）；替代历史写死的单 ZhangDuo
NOTIFY_DEFAULT_TUSERS=ZhangDuo

# 企微「通讯录同步」功能回调验证（架构 §7.1.2）：企微后台「管理工具→通讯录同步→API接口同步」生成
# 用于 functions/wecom-contacts-webhook 的 GET 验证签名 + POST 解密（非 API 调用，与 WECOM_OPS_SECRET 无关）
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=

# ============ 智能问数（架构文档 §4.2） ============
# agent-query 网关 ↔ duckdb /query 的共享鉴权密钥。
# 同时注入四处：① duckdb 服务 env（compose 读此变量）② agent-query function secret（deploy-functions.sh 读此变量）
#            ③ openclaw 容器 env（compose openclaw 服务读此变量，供 data-query 插件转发到网关，§4.3）
#            ④ web 容器 env（compose web 服务，供 notifyWecom 调 wecom-notify 鉴权，§7.1.1）
# 生产值用强随机串（openssl rand -hex 32），不入库不入 transcript
AGENT_API_KEY=

# ============ 生产网关 / 证书 ============
DOMAIN=data.example.com
# Let's Encrypt 证书申请邮箱（过期提醒用）
LETSENCRYPT_EMAIL=you@example.com
# =1 使用 LE 测试环境（不限频、颁发测试证书），调试期打开，稳定后改 0
LETSENCRYPT_STAGING=0

# ============ 可选 ============
# 前端构建 npm 源（国内镜像；海外可改 https://registry.npmjs.org）
NPM_REGISTRY=https://registry.npmmirror.com

# ============ 企微通讯录同步 ============
# 注意：企微应用需配置「通讯录」权限
# 同步方式1：服务器 cron 每日 02:00 执行（手动定时）
# 同步方式2：实时推送（配置接收事件服务器）
# 手动触发：curl -X POST https://data.shanhaiyiguo.com/functions/wecom-sync-contacts

# 通讯录变更事件推送配置（用于实时同步）
# 在企微后台「通讯录同步」→「设置接收事件服务器」中配置以下参数
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=
# 接收事件服务器 URL：https://data.shanhaiyiguo.com/functions/wecom-contacts-webhook

{
  // Gateway 配置（必须）
  gateway: {
    mode: "local",
    bind: "lan",
    port: 18789,
  },

  // 模型配置
  models: {
    providers: {
      "wishub": {
        baseUrl: "https://wishub-x6.ctyun.cn/v1",
        api: "openai-completions",
        apiKey: "${WISHUB_API_KEY}",
        models: [
          {
            id: "DeepSeek-V4-Flash",
            name: "DeepSeek V4 Flash",
            input: ["text"],
            contextWindow: 128000,
            maxTokens: 8192,
          },
        ],
      },
    },
  },

  // 默认模型
  agents: {
    defaults: {
      model: "wishub/DeepSeek-V4-Flash",
    },
  },
}